---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Card } from '@mfranceschit/ui';
import { useTranslations, getStaticLocalePaths } from '@/i18n/utils';
import type { Locale } from '@/i18n/utils';
import { getCertifications, getDegrees } from '@/lib/sanity';

export function getStaticPaths() {
  return getStaticLocalePaths();
}

const { locale } = Astro.params as { locale: Locale };
const t = useTranslations(locale);
const [certifications, degrees] = await Promise.all([
  getCertifications(locale),
  getDegrees(locale),
]);
---

<BaseLayout
  title={t('meta.certifications.title')}
  description={t('meta.certifications.description')}
  lang={locale}
  currentPath="/certifications"
>
  <section class="max-w-2xl mx-auto px-6 pt-14 pb-20">
    <h1 class="text-[35px] font-bold text-bellwether-blue mb-10" style="letter-spacing: -0.015em;">
      {t('certifications.title')}
    </h1>

    <h2 class="text-[22px] font-semibold text-[var(--mf-gray-900)] mb-3.5">
      {t('certifications.certificates')}
    </h2>
    <ul class="flex flex-col gap-3 mb-9">
      {
        certifications.map((cert) => (
          <Card as="li">
            <div class="flex items-center gap-4 p-4">
              {cert.image ? (
                <img
                  src={cert.image}
                  alt={cert.name}
                  class="w-12 h-12 object-contain rounded-md shrink-0"
                />
              ) : (
                <div
                  class="w-12 h-12 rounded-md shrink-0 flex items-center justify-center"
                  style="background: var(--mf-sand);"
                >
                  <img src="/monogram-navy.svg" alt="MFT" style="height: 28px; width: auto;" />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-[var(--mf-gray-900)] text-sm">{cert.name}</p>
                {cert.issued && (
                  <p class="text-xs text-[var(--text-muted)] mt-0.5">{cert.issued}</p>
                )}
              </div>
              <div class="flex items-center gap-3 shrink-0">
                {cert.date && (
                  <span class="text-xs text-[var(--text-faint)] tabular-nums">{cert.date}</span>
                )}
                {cert.url && (
                  <a
                    href={cert.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-silver-birch no-underline hover:text-very-berry transition-colors duration-[120ms]"
                  >
                    {t('projects.view')} →
                  </a>
                )}
              </div>
            </div>
          </Card>
        ))
      }
    </ul>

    <h2 class="text-[22px] font-semibold text-[var(--mf-gray-900)] mb-3.5">
      {t('certifications.degrees')}
    </h2>
    <ul class="flex flex-col gap-3">
      {
        degrees.map((degree) => (
          <Card as="li">
            <div class="flex items-center gap-4 p-4">
              {degree.image ? (
                <img
                  src={degree.image}
                  alt={degree.name}
                  class="w-12 h-12 object-contain rounded-md shrink-0"
                />
              ) : (
                <div
                  class="w-12 h-12 rounded-md shrink-0 flex items-center justify-center"
                  style="background: var(--mf-sand);"
                >
                  <img src="/monogram-navy.svg" alt="MFT" style="height: 28px; width: auto;" />
                </div>
              )}
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-[var(--mf-gray-900)] text-sm">{degree.name}</p>
                {degree.issued && (
                  <p class="text-xs text-[var(--text-muted)] mt-0.5">{degree.issued}</p>
                )}
              </div>
            </div>
          </Card>
        ))
      }
    </ul>
  </section>
</BaseLayout>
