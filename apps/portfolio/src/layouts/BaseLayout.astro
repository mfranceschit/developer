---
import '@/styles/global.css';
import { MobileNav } from '@mfranceschit/ui';
import { ClientRouter } from 'astro:transitions';
import LanguagePicker from '@/components/LanguagePicker.astro';
import { languages } from '@/i18n/ui';
import HeaderWave from '@/components/islands/HeaderWave.svelte';
import TramaBackground from '@/components/islands/TramaBackground.svelte';
import { locales, useTranslatedPath, useTranslations } from '@/i18n/utils';
import type { Locale } from '@/i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang: Locale;
  currentPath: string;
  variant?: 'hero' | 'interior';
}

const {
  title,
  description = 'mfranceschit — developer',
  lang,
  currentPath,
  variant = 'interior',
} = Astro.props;
const tp = useTranslatedPath(lang);
const t = useTranslations(lang);
const isHero = variant === 'hero';

const canonicalUrl = new URL(`/${lang}${currentPath}`, Astro.site).href;
const alternateUrls = locales.map((code) => ({
  code,
  href: new URL(`/${code}${currentPath}`, Astro.site).href,
}));
const defaultUrl = new URL('/', Astro.site).href;
const ogImageUrl = new URL('/og-image.png', Astro.site).href;

const navLinks = [
  { href: '/', label: t('nav.home') },
  { href: '/about', label: t('nav.about') },
  { href: '/projects', label: t('nav.projects') },
  { href: '/certifications', label: t('nav.certifications') },
  { href: '/contact', label: t('nav.contact') },
];

const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);

const mobileLinks = navLinks.map(({ href, label }) => ({
  href: tp(href),
  label,
  active: isActive(href),
}));

const mobileLanguages = Object.entries(languages).map(([code, label]) => ({
  href: `/${code}${currentPath}`,
  label: label.slice(0, 2).toUpperCase(),
  active: lang === code,
}));
---

<!doctype html>
<html lang={lang} data-theme="dark" class="bg-[var(--surface-page)]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrls.map(({ code, href }) => <link rel="alternate" hreflang={code} href={href} />)}
    <link rel="alternate" hreflang="x-default" href={defaultUrl} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1B2B5B" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <ClientRouter />
  </head>
  <body class="min-h-screen bg-[image:var(--gradient-page)] bg-fixed font-sans text-[var(--text-heading-strong)]">
    {variant === 'interior' && <TramaBackground client:visible waveEnergy={0.75} />}
    <header
      class:list={[
        'fixed left-0 right-0 top-0 z-30 flex h-16 items-center justify-between gap-6 px-7',
        isHero
          ? 'border-b border-[var(--border-hairline)] bg-[var(--surface-header-glass)] backdrop-blur-[14px]'
          : 'bg-[var(--surface-header)]',
      ]}
    >
      <a href={tp('/')} class="mf-wordmark text-[15px] font-semibold text-white no-underline">
        mfranceschit
      </a>
      <nav class="hidden items-center gap-[26px] md:flex">
        {
          navLinks.map(({ href, label }) => {
            const active = isActive(href);
            return (
              <a
                href={tp(href)}
                data-pluck
                class:list={[
                  'border-b-2 py-1 text-[13.5px] no-underline transition-colors duration-200',
                  active
                    ? 'border-very-berry font-semibold text-white'
                    : 'border-transparent font-normal text-[var(--text-nav)] hover:text-white',
                ]}
              >
                {label}
              </a>
            );
          })
        }
      </nav>
      <div class="hidden md:block">
        <LanguagePicker lang={lang} currentPath={currentPath} />
      </div>
      <MobileNav
        client:load
        className="md:hidden"
        links={mobileLinks}
        languages={mobileLanguages}
        triggerLabel={t('nav.openMenu')}
        closeLabel={t('nav.closeMenu')}
      />
    </header>
    {variant === 'interior' && <HeaderWave client:load transition:persist="header-wave" waveEnergy={0.75} />}
    <main class="relative z-10 pt-16">
      <slot />
    </main>
  </body>
</html>
