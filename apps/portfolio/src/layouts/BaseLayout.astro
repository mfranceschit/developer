---
import '@/styles/global.css';
import LanguagePicker from '@/components/LanguagePicker.astro';
import { useTranslatedPath, useTranslations } from '@/i18n/utils';
import type { Locale } from '@/i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang: Locale;
  currentPath: string;
}

const { title, description = 'mfranceschit — developer', lang, currentPath } = Astro.props;
const tp = useTranslatedPath(lang);
const t = useTranslations(lang);

const navLinks = [
  { href: '/', label: t('nav.home') },
  { href: '/about', label: t('nav.about') },
  { href: '/projects', label: t('nav.projects') },
  { href: '/certifications', label: t('nav.certifications') },
  { href: '/contact', label: t('nav.contact') },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body class="min-h-screen bg-white font-sans">
    <header
      class="sticky top-0 z-10 h-16 flex items-center justify-between gap-6 px-7 border-b border-[var(--border-subtle)]"
      style="background: rgba(255,255,255,0.82); backdrop-filter: blur(10px);"
    >
      <a href={tp('/')} class="mf-wordmark text-[18px] text-bellwether-blue no-underline">
        mfranceschit
      </a>
      <nav class="flex items-center gap-6">
        {
          navLinks.map(({ href, label }) => {
            const active =
              href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <a
                href={tp(href)}
                class:list={[
                  'text-sm transition-colors duration-[120ms] py-1 border-b-2 no-underline',
                  active
                    ? 'font-semibold text-bellwether-blue border-very-berry'
                    : 'font-normal text-[var(--mf-gray-600)] border-transparent hover:text-very-berry',
                ]}
              >
                {label}
              </a>
            );
          })
        }
      </nav>
      <LanguagePicker lang={lang} currentPath={currentPath} />
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
