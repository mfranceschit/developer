---
import '@/styles/global.css';
import LanguagePicker from '@/components/LanguagePicker.astro';
import HeaderWave from '@/components/islands/HeaderWave.svelte';
import TramaBackground from '@/components/islands/TramaBackground.svelte';
import { locales, useTranslatedPath, useTranslations } from '@/i18n/utils';
import type { Locale } from '@/i18n/utils';

interface Props {
  title: string;
  description?: string;
  lang: Locale;
  currentPath: string;
  variant?: 'hero' | 'interior';
}

const {
  title,
  description = 'mfranceschit — developer',
  lang,
  currentPath,
  variant = 'interior',
} = Astro.props;
const tp = useTranslatedPath(lang);
const t = useTranslations(lang);
const isHero = variant === 'hero';

const canonicalUrl = new URL(`/${lang}${currentPath}`, Astro.site).href;
const alternateUrls = locales.map((code) => ({
  code,
  href: new URL(`/${code}${currentPath}`, Astro.site).href,
}));
const defaultUrl = new URL('/', Astro.site).href;

const navLinks = [
  { href: '/', label: t('nav.home') },
  { href: '/about', label: t('nav.about') },
  { href: '/projects', label: t('nav.projects') },
  { href: '/certifications', label: t('nav.certifications') },
  { href: '/contact', label: t('nav.contact') },
];
---

<!doctype html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    {alternateUrls.map(({ code, href }) => <link rel="alternate" hreflang={code} href={href} />)}
    <link rel="alternate" hreflang="x-default" href={defaultUrl} />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body class="min-h-screen bg-[image:var(--gradient-page)] bg-fixed font-sans text-[var(--text-heading-strong)]">
    {variant === 'interior' && <TramaBackground client:visible waveEnergy={0.75} />}
    <header
      class:list={[
        'fixed left-0 right-0 top-0 z-30 flex h-16 items-center justify-between gap-6 px-7',
        isHero
          ? 'border-b border-[var(--border-hairline)] bg-[var(--surface-header-glass)] backdrop-blur-[14px]'
          : 'bg-[var(--surface-header)]',
      ]}
    >
      <a href={tp('/')} class="mf-wordmark text-[15px] font-semibold text-white no-underline">
        mfranceschit
      </a>
      <nav class="flex items-center gap-[26px]">
        {
          navLinks.map(({ href, label }) => {
            const active =
              href === '/' ? currentPath === '/' : currentPath.startsWith(href);
            return (
              <a
                href={tp(href)}
                data-pluck
                class:list={[
                  'border-b-2 py-1 text-[13.5px] no-underline transition-colors duration-200',
                  active
                    ? 'border-very-berry font-semibold text-white'
                    : 'border-transparent font-normal text-[var(--text-nav)] hover:text-white',
                ]}
              >
                {label}
              </a>
            );
          })
        }
      </nav>
      <LanguagePicker lang={lang} currentPath={currentPath} />
    </header>
    {variant === 'interior' && <HeaderWave client:load waveEnergy={0.75} />}
    <main class="relative z-10 pt-16">
      <slot />
    </main>
  </body>
</html>
